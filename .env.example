################################
# CHANGE BEFORE PRODUCTION USE #
################################

# Database Configuration
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nextbike_data
DB_USER=bike_admin
DB_PASSWORD=changeme
DB_BIKES_TABLE=public.bikes
DB_STATIONS_TABLE=public.stations
DB_CITIES_TABLE=public.cities

# Cities to collect (comma-separated)
# Find city IDs at: https://maps.nextbike.net/maps/nextbike-live.json
CITY_IDS=467

# Collection Intervals
# Stations are collected daily (24 hours = 1 day)
STATIONS_SYNC_INTERVAL_HOURS=24
# Cities metadata collected monthly (30 days)
CITIES_SYNC_INTERVAL_HOURS=720

# Data export output directory (mounted into the processor container)
EXPORT_DIR=/data

# Visualization port
VISUALIZATION_PORT=8080
